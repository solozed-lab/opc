---
import "../styles/global.css";

const siteUrl = "https://opc.solozed.com/";
const siteTitle = "D.J.C | AI 时代的一人公司方法论";
const siteDescription =
  "D.J.C，AI 时代的一人公司方法论：拆解（Dismantle）、判断（Judge）、成事（Complete）。面向独立创造者与 AI 转型经营者，提供从战略到落地的一体化陪跑。";
const ogImage = new URL("/images/djc-noir-door.png", siteUrl).toString();

const frameworkCards = [
  {
    number: "01",
    title: "拆解",
    label: "Dismantle",
    body: "把混杂的问题拆到能判断、能行动、能验证的颗粒度。",
    foot: "Input / Structured",
  },
  {
    number: "02",
    title: "判断",
    label: "Judge",
    body: "在信息噪音中识别边界、代价、优先级和真正的信号。",
    foot: "Noise / Signal",
    featured: true,
  },
  {
    number: "03",
    title: "成事",
    label: "Complete",
    body: "把判断变成路径，把路径变成结果，让复杂的事稳定落地。",
    foot: "Decision / Delivered",
  },
];

const services = [
  ["01", "战略拆解", "Strategy Dismantle", "把目标、约束、资源和卡点拆清楚，找到真正值得先做的事。"],
  ["02", "业务诊断", "Business Diagnosis", "用 2-4 周看清业务里的关键变量，减少盲目投入。"],
  ["03", "决策陪跑", "Decision Partner", "在关键节点一起判断噪音、信号、风险和下一步。"],
  ["04", "AI 工作流落地", "AI Workflow", "把 AI 接进研究、设计、交付与复盘，而不是停在工具尝鲜。"],
  ["05", "内容结构化", "Content System", "把复杂内容整理成能传播、能复用、能持续迭代的结构。"],
  ["06", "持续迭代", "Continuous Iteration", "做一步，看一步，把结果反馈进下一轮判断。"],
];

const proofPoints = [
  "OPC",
  "AI ERA",
  "SHANGHAI",
  "DISMANTLE / JUDGE / COMPLETE",
];

const faqs = [
  {
    question: "什么是 D.J.C？",
    answer:
      "D.J.C 是一人公司方法论的实践品牌，核心方法是 Dismantle（拆解）、Judge（判断）、Complete（成事）三步法，把复杂问题拆到颗粒度，在信息噪音中做判断，把事稳定做成。",
  },
  {
    question: "D.J.C 提供哪些服务？",
    answer:
      "D.J.C 提供战略拆解、业务诊断、决策陪跑、AI 工作流落地、内容结构化和持续迭代支持。",
  },
  {
    question: "一次咨询的流程是怎样的？",
    answer:
      "从一次不超过 30 分钟的对话开始，先看清什么是噪音、什么是正在发生的事，再决定是否进入 2-4 周的深度陪跑。",
  },
  {
    question: "适合谁？",
    answer:
      "适合一人公司创始人、独立创造者，以及正在把 AI 接进研究、设计、交付与复盘环节的经营者。",
  },
];

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": `${siteUrl}#person`,
      name: "D.J.C",
      alternateName: "Dismantle Judge Complete",
      description:
        "AI 时代的一人公司方法论。拆解（Dismantle）、判断（Judge）、成事（Complete）三步法，面向独立创造者与 AI 转型经营者，提供从战略到落地的一体化陪跑。",
      url: siteUrl,
      jobTitle: "One Person Company",
      knowsAbout: ["AI 工作流落地", "独立创造者战略", "业务诊断", "决策陪跑", "内容结构化", "长期主义"],
      workLocation: {
        "@type": "Place",
        address: {
          "@type": "PostalAddress",
          addressLocality: "Shanghai",
          addressCountry: "CN",
        },
      },
      sameAs: ["https://x.com/XianlaiSolo"],
    },
    {
      "@type": "WebSite",
      "@id": `${siteUrl}#website`,
      url: siteUrl,
      name: "D.J.C",
      description: siteDescription,
      inLanguage: "zh-CN",
      publisher: {
        "@id": `${siteUrl}#person`,
      },
    },
    {
      "@type": "WebPage",
      "@id": `${siteUrl}#webpage`,
      url: siteUrl,
      name: siteTitle,
      description: siteDescription,
      isPartOf: {
        "@id": `${siteUrl}#website`,
      },
      about: {
        "@id": `${siteUrl}#person`,
      },
      inLanguage: "zh-CN",
    },
    {
      "@type": "FAQPage",
      "@id": `${siteUrl}#faq`,
      mainEntity: faqs.map((faq) => ({
        "@type": "Question",
        name: faq.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: faq.answer,
        },
      })),
    },
  ],
};
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" sizes="32x32" href="/icons/djc-icon-noir-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/icons/djc-icon-noir-180.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#090807" />
    <meta name="description" content={siteDescription} />
    <meta name="author" content="D.J.C" />
    <link rel="canonical" href={siteUrl} />
    <title>{siteTitle}</title>

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="D.J.C" />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={siteDescription} />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1672" />
    <meta property="og:image:height" content="941" />
    <meta property="og:image:alt" content="黑色空间里一道门缝透出金色光线" />
    <meta property="og:locale" content="zh_CN" />

    <meta name="twitter:card" content="summary_large_image" />
