          <source src="/videos/djc-door-light-loop.mp4" type="video/mp4" />
        </video>
        <div class="hero-shade" aria-hidden="true"></div>

        <div class="hero-inner">
          <p class="eyebrow reveal">One Person Company / AI Era</p>
          <div class="hero-grid">
            <div class="hero-copy reveal">
              <h1 class="type-title">
                <span class="type-line type-line-1">AI 时代，</span><br />
                <span class="type-line type-line-2">值得更加<span class="accent">从容</span></span>
              </h1>
              <p class="script-line">Composer in the Age of AI</p>
              <p class="hero-text">
                在信息噪音中，保持清醒判断；在复杂世界里，完成真正重要的事。
              </p>
              <p class="english-line">
                Dismantle the problem. Judge the noise. Complete the work.
              </p>
              <div class="hero-actions">
                <button class="primary-button contact-trigger" type="button">开启一次对话</button>
                <a class="ghost-button" href="#framework">了解方法论</a>
              </div>
            </div>

            <aside class="hero-index reveal" aria-label="D.J.C 元信息">
              <p><span class="rolling-number" data-target="31.2304">31.2304</span>° N</p>
              <p><span class="rolling-number" data-target="121.4737">121.4737</span>° E</p>
              <p>Shanghai</p>
              <p>Est. 2026</p>
            </aside>
          </div>

          <div class="proof-strip reveal" aria-label="页面关键词">
            {proofPoints.map((item) => <span>{item}</span>)}
          </div>
        </div>
      </section>

      <section id="framework" class="framework section-shell">
        <p class="section-kicker reveal">01 / The Framework</p>
        <div class="section-title-row reveal">
          <h2>拆解 · 判断 · 成事</h2>
          <div class="section-title-sub">
            <p class="script-line">Dismantle · Judge · Complete</p>
            <p>不是三件独立的事，而是一套从混乱到结果的顺序。</p>
          </div>
        </div>

        <div class="framework-grid">
          {
            frameworkCards.map((card) => (
              <article class:list={["framework-card", "reveal", { featured: card.featured }]}>
                <span class="card-number">{card.number}</span>
                <h3>{card.title}</h3>
                <p class="card-label">{card.label}</p>
                <p>{card.body}</p>
                <strong>{card.foot}</strong>
              </article>
            ))
          }
        </div>
      </section>

      <section id="work" class="work">
        <div class="section-shell">
          <p class="section-kicker reveal">02 / What I Do</p>
          <div class="work-intro reveal">
            <h2>我所做的事</h2>
            <p>
              为一人公司与创造者，提供从战略到落地的一体化支持：先看清，再推进。
            </p>
          </div>

          <div class="service-grid">
            {
              services.map(([number, title, label, body]) => (
                <article class="service-card reveal">
                  <span>{number}</span>
                  <div>
                    <h3>{title}</h3>
                    <p class="card-label">{label}</p>
                  </div>
                  <p>{body}</p>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section id="belief" class="belief">
        <div class="belief-copy reveal">
          <p class="section-kicker">03 / A Note on Composure</p>
          <h2>从容哲学</h2>
          <p class="script-line">A Note on Composure</p>
          <div class="belief-text">
            <p>AI 让一切加速，也让人更焦虑。它同时给了我们一件罕见的礼物：时间。</p>
            <p>D.J.C 是一人公司，是一个人，但不是单打独斗。因为我不想成为热闹里的一部分，而想成为在工具变快时仍能看清、能判断、能把事情做成的人。</p>
            <p>大多数混乱，不是因为资源太少，而是因为重要变量被稀释。拆完之后，问题常常就只剩一种能力：判断，接着让这个更小的问题一步一步被推进。</p>
            <p><strong>不做更多的事，只做最重要的事。不追逐每个机会，只保持独立、清醒、长期主义。</strong></p>
          </div>
        </div>
        <figure class="belief-image reveal">
 <img
 src="/images/djc-noir-stairs.png"
 alt="暗色台阶通向一道发光的门"
 width="1536"
 height="1024"
 loading="lazy"
 decoding="async"
 />
 </figure>
      </section>

      <section id="contact" class="begin">
        <div class="begin-inner reveal">
          <p class="center-kicker">04 / Begin</p>
          <h2>从一次拆解开始</h2>
          <p class="script-line">Start with a single dismantle</p>
          <p>
            一次不超过 30 分钟的对话。先不急着选择答案，一起看看：
            什么是噪音，什么才是正在发生的事。
          </p>
          <button class="primary-button light contact-trigger" type="button">开启一次对话</button>
          <small>适合一人公司、独立创造者、AI 转型中的经营者。</small>
        </div>
      </section>

      <section id="faq" class="faq section-shell">
        <p class="section-kicker reveal">05 / Questions</p>
        <div class="faq-layout">
          <div class="faq-intro reveal">
            <h2>常见问题</h2>
            <p class="script-line">What search engines and people should know</p>
          </div>
          <div class="faq-list">
            {
              faqs.map((faq) => (
                <article class="faq-item reveal">
                  <h3>{faq.question}</h3>
                  <p>{faq.answer}</p>
                </article>
              ))
            }
          </div>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="footer-brand">
        <strong>D.J.C</strong>
        <p>Dismantle · Judge · Complete</p>
        <p>拆解问题，判断方向，把事做成。</p>
      </div>
      <div>
        <h4>方法</h4>
        <a href="#framework">拆解 Dismantle</a>
        <a href="#framework">判断 Judge</a>
        <a href="#framework">成事 Complete</a>
      </div>
      <div>
        <h4>服务</h4>
        <a href="#work">战略拆解</a>
        <a href="#work">业务诊断</a>
        <a href="#work">AI 工作流落地</a>
      </div>
      <div>
        <h4>联系</h4>
        <a href="mailto:i@solozed.com">i@solozed.com</a>
        <a href="https://x.com/XianlaiSolo" target="_blank" rel="noreferrer">X / @XianlaiSolo</a>
        <a href="#contact">WeChat / aptx9089</a>
      </div>
      <p class="copyright">© 2026 D.J.C · All rights reserved.</p>
      <p class="location">Built with clarity and discipline.</p>
    </footer>

    <dialog class="contact-dialog" aria-labelledby="contact-dialog-title">
      <div class="dialog-head">
        <div>
          <p class="section-kicker">Begin</p>
          <h2 id="contact-dialog-title">选择一种方式</h2>
        </div>
        <button class="dialog-close" type="button" aria-label="关闭联系弹窗">×</button>
      </div>

      <div class="dialog-options">
        <a class="dialog-option" href="mailto:i@solozed.com">
          <span>Email</span>
          <strong>i@solozed.com</strong>
        </a>
        <a class="dialog-option" href="https://x.com/XianlaiSolo" target="_blank" rel="noreferrer">
          <span>X</span>
          <strong>@XianlaiSolo</strong>
        </a>
        <button class="dialog-option wechat-toggle" type="button" aria-expanded="false" aria-controls="wechat-contact">
          <span>WeChat</span>
          <strong>aptx9089</strong>
        </button>
      </div>

      <div id="wechat-contact" class="wechat-contact" hidden>
        <img src="/images/wechat-user-noir.png" alt="微信二维码，扫码添加 aptx9089" />
        <p>微信号：<strong>aptx9089</strong></p>
      </div>
    </dialog>

    <script>
      const revealItems = document.querySelectorAll(".reveal");
      const header = document.querySelector(".site-header");
      const contactDialog = document.querySelector(".contact-dialog");
      const contactTriggers = document.querySelectorAll(".contact-trigger");
      const dialogClose = document.querySelector(".dialog-close");
      const wechatToggle = document.querySelector(".wechat-toggle");
      const wechatContact = document.querySelector("#wechat-contact");
      const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      const setHeaderState = () => {
        header?.classList.toggle("is-scrolled", window.scrollY > 24);
      };

      setHeaderState();
      window.addEventListener("scroll", setHeaderState, { passive: true });

      contactTriggers.forEach((trigger) => {
        trigger.addEventListener("click", () => {
          if (typeof contactDialog?.showModal === "function") {
            contactDialog.showModal();
          }
        });
      });

      dialogClose?.addEventListener("click", () => contactDialog?.close());

      contactDialog?.addEventListener("click", (event) => {
        if (event.target === contactDialog) {
          contactDialog.close();
        }
      });

      wechatToggle?.addEventListener("click", () => {
        const isOpen = wechatToggle.getAttribute("aria-expanded") === "true";
        wechatToggle.setAttribute("aria-expanded", String(!isOpen));
        wechatContact.hidden = isOpen;
      });

      const animateCoordinates = () => {
        const coordinateItems = document.querySelectorAll(".rolling-number");

        coordinateItems.forEach((item, index) => {
          const target = Number(item.dataset.target);
          const start = target - (index === 0 ? 1.8647 : 2.3914);
          const duration = 1400 + index * 220;
          const startTime = performance.now();

          const tick = (now) => {
            const progress = Math.min((now - startTime) / duration, 1);
            const eased = 1 - Math.pow(1 - progress, 4);
            const value = start + (target - start) * eased;

            item.textContent = value.toFixed(4);

            if (progress < 1) {
              requestAnimationFrame(tick);
            } else {
              item.textContent = target.toFixed(4);
            }
          };

          requestAnimationFrame(tick);
        });
      };

      if (reducedMotion) {
        document.querySelectorAll("video").forEach((video) => {
          video.pause();
          video.currentTime = 0;
        });

        revealItems.forEach((item) => item.classList.add("is-visible"));
        document.querySelectorAll(".rolling-number").forEach((item) => {
          item.textContent = Number(item.dataset.target).toFixed(4);
        });
      } else {
        animateCoordinates();

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.16 }
        );

        revealItems.forEach((item) => observer.observe(item));
      }
    </script>
  </body>
</html>
